# 4-digit PIN required to access the web terminal
HERMES_PIN=1234

# Command to run inside each new tmux session (defaults to `hermes`)
# Used by the `+` button. Profile entries from the `⌄` dropdown always run `hermes -p <profile>`.
# HERMES_CMD=hermes
# HERMES_ARGS=

# Where hermes profile directories live — one subdirectory per profile.
# Defaults to ~/.hermes/profiles
# HERMES_PROFILES_DIR=/home/you/.hermes/profiles

# JSON file mapping shortcut names to commands, shown alongside profiles in the
# `⌄` dropdown. Handy on a phone, where the goal is "less typing". Format:
#   { "claude": "claude", "pi": "ssh pi@example.com" }
# Defaults to ./shortcuts.json next to this .env (file is optional).
# HERMES_SHORTCUTS_FILE=/path/to/shortcuts.json

# Prefix used for the tmux session names — handy if you also use tmux for other things
# TMUX_SESSION_PREFIX=hermes-

# Bind address and port
# HOST=0.0.0.0
# PORT=3003
